<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Results - SpeedTyper</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <main class="results-page">
        <h1>Results</h1>

        <section class="results-card">
            <div class="result-item">
                <h2>Mistakes</h2>
                <p><%= mistakes %></p>
            </div>

            <div class="result-item">
                <h2>Speed</h2>
                <p><%= speed %> WPM</p>
            </div>
        </section>

        <form action="/save-score" method="POST" class="save-score-form">
            <label for="username">Enter your username:</label>

            <input
                type="text"
                id="username"
                name="username"
                placeholder="Enter username"
                maxlength="20"
                required
            >

            <input type="hidden" name="speed" value="<%= speed %>">
            <input type="hidden" name="mistakes" value="<%= mistakes %>">

            <div class="button-group">
                <button type="submit">
                    Save Score & Continue
                </button>

                <a href="/" class="skip-link">
                    Skip & Continue
                </a>
            </div>
        </form>
    </main>
</body>
</html>