<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SpeedTyper Challenge</title>

    <link rel="stylesheet" href="/style.css">
</head>

<body class="typing-page">

    <div class="page-container">

        <div class="header">
            <h1>Typing Challenge</h1>
            <p>Type the paragraph below as accurately and quickly as possible.</p>
        </div>

        <!-- STATS ROW -->
        <div class="stats-container">

            <div class="stat-box">
                <div class="stat-title">Time</div>
                <div class="stat-value">60s</div>
            </div>

            <div class="stat-box">
                <div class="stat-title">Mistakes</div>
                <div class="stat-value">0</div>
            </div>

            <div class="stat-box">
                <div class="stat-title">Progression</div>
                <div class="stat-value">0%</div>
            </div>

        </div>

        <div class="text-container">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit.
            Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
            Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris
            nisi ut aliquip ex ea commodo consequat.
        </div>

        <div class="typing-container">
            <textarea
                class="typing-input"
                placeholder="Start typing here..."
            ></textarea>
        </div>

    </div>

</body>

</html>